CREATE TABLE objects (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nom VARCHAR(255) NOT NULL,
    prix DECIMAL(10, 2) NOT NULL,
    reduction INT DEFAULT 0,
    genre VARCHAR(100),
    description TEXT
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 4. Table des images
CREATE TABLE images_objet (
    id INT AUTO_INCREMENT PRIMARY KEY,
    objet_id INT NOT NULL,
    chemin_img VARCHAR(255) NOT NULL,
    CONSTRAINT fk_images_objects FOREIGN KEY (objet_id) 
        REFERENCES objects(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 5. Table des couleurs
CREATE TABLE couleur_objet (
    id INT AUTO_INCREMENT PRIMARY KEY,
    objet_id INT NOT NULL,
    nom_couleur VARCHAR(100) NOT NULL,
    CONSTRAINT fk_couleur_objects FOREIGN KEY (objet_id) 
        REFERENCES objects(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 6. Table des tailles (Note le 's' à objets comme sur ton image)
CREATE TABLE taille_objets (
    id INT AUTO_INCREMENT PRIMARY KEY,
    objet_id INT NOT NULL,
    nom_taille VARCHAR(100) NOT NULL,
    stock INT DEFAULT 0,
    CONSTRAINT fk_taille_objects FOREIGN KEY (objet_id) 
        REFERENCES objects(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

